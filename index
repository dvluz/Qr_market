<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>eMarket Super</title>
    <link href="https://fonts.cdnfonts.com/css/digital-numbers" rel="stylesheet">
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
        :root {
            --primary: #2c3e50; --accent: #27ae60; --danger: #e74c3c;
            --vfd-bg: #050505; --vfd-cyan: #00ffff; --vfd-cyan-glow: rgba(0, 255, 255, 0.4);
        }
        body { font-family: 'Segoe UI', sans-serif; background-color: #dcdde1; display: flex; justify-content: center; padding: 5px; margin: 0; }
        .app-container { width: 100%; max-width: 450px; background: white; min-height: 95vh; padding: 10px 15px; border-radius: 15px; box-sizing: border-box; }
        h1 { text-align: center; color: var(--primary); font-size: 1.3rem; margin: 5px 0 10px 0; }
        h2 { font-size: 1rem; margin: 2px 0 10px 0; color: var(--primary); text-align: center; }
        .vfd-dashboard { background: var(--vfd-bg); color: var(--vfd-cyan); padding: 10px; border-radius: 8px; display: flex; justify-content: space-around; align-items: center; margin-bottom: 15px; font-family: 'Digital Numbers', sans-serif; border: 2px solid #222; box-shadow: inset 0 0 10px rgba(0,0,0,1); }
        .vfd-value { font-size: 1.1rem; text-shadow: 0 0 5px var(--vfd-cyan-glow); }
        .vfd-label { font-size: 0.6rem; color: rgba(0, 255, 255, 0.4); }
        button { padding: 14px; border: none; border-radius: 8px; background-color: var(--primary); color: white; font-size: 14px; font-weight: bold; cursor: pointer; width: 100%; }
        .btn-sucesso { background-color: var(--accent); }
        .btn-perigo { background-color: var(--danger); margin-top: 5px; }
        .btn-voltar { background-color: #7f8c8d; margin-top: 8px; }
        .btn-scan { background-color: #3498db; margin-bottom: 10px; padding: 10px; font-size: 12px; }
        .tela { display: none; } .tela.ativa { display: block; }
        .campo { margin-bottom: 6px; }
        .campo label { display: block; margin-bottom: 2px; font-weight: bold; font-size: 0.8rem; }
        input { width: 100%; padding: 8px; border: 2px solid #eee; border-radius: 6px; box-sizing: border-box; font-size: 16px; }
        .form-row-compact { display: flex; justify-content: space-between; gap: 10px; margin-bottom: 5px; }
        .form-col-50 { flex: 0 0 48%; }
        #reader { width: 100%; background: #000; border-radius: 8px; overflow: hidden; margin-bottom: 10px; display: none; min-height: 200px; }
        .item-carrinho { display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #f1f1f1; cursor: pointer; font-size: 0.9rem; }
        .item-carrinho div strong::before { content: '✎ '; color: var(--primary); margin-right: 3px; }
        .total-rodape { margin-top: 10px; padding: 10px; background: #f8f9fa; border-radius: 6px; border-left: 4px solid var(--accent); display: flex; justify-content: space-between; font-weight: bold; }
    </style>
</head>
<body>
<div class="app-container">
    <div id="telaInicial" class="tela ativa">
        <h1>eMarket Super</h1>
        <div class="vfd-dashboard">
            <div class="vfd-item" style="text-align: center; flex: 1;"><span class="vfd-label">ITENS</span><br><strong class="vfd-value" id="homeQtd">00</strong></div>
            <div class="vfd-item" style="text-align: center; flex: 1; border-left: 1px solid rgba(0,255,255,0.1);"><span class="vfd-label">TOTAL R$</span><br><strong class="vfd-value" id="homeTotal">0.00</strong></div>
        </div>
        <button onclick="prepararAdd()">➕ Adicionar Produto</button>
        <button onclick="navegar('telaCarrinho')" style="margin-top: 10px;">🛒 Ver Carrinho</button>
        <button onclick="navegar('telaFinalizar')" class="btn-sucesso" style="margin-top: 10px;">🏁 Finalizar Compra</button>
    </div>

    <div id="telaAdd" class="tela">
        <h2 id="tituloAcao">Novo Produto</h2>
        <div id="reader"></div>
        <button id="btnAbrirScan" class="btn-scan" onclick="alternarScanner()">📷 Ler Código de Barras</button>
        <input type="hidden" id="editIndex">
        <div class="campo"><label>Descrição/Código</label><input type="text" id="desc" placeholder="Nome ou Código"></div>
        <div class="form-row-compact">
            <div class="form-col-50"><div class="campo"><label>Quantidade</label><input type="number" id="qtd" value="1"></div></div>
            <div class="form-col-50"><div class="campo"><label>Valor Unitário</label><input type="number" id="valor" step="0.01" placeholder="0.00"></div></div>
        </div>
        <button class="btn-sucesso" onclick="salvarProduto()">Confirmar</button>
        <button id="btnExcluir" class="btn-perigo" onclick="excluirProduto()">Excluir Item</button>
        <button class="btn-voltar" onclick="pararScanner(); navegar('telaInicial');">Voltar</button>
    </div>

    <div id="telaCarrinho" class="tela">
        <h2>Carrinho</h2>
        <div id="listaCarrinho"></div>
        <div class="total-rodape"><span>Subtotal:</span><span id="carrinhoSubtotal">R$ 0,00</span></div>
        <button class="btn-voltar" onclick="navegar('telaInicial')">Voltar</button>
    </div>

    <div id="telaFinalizar" class="tela">
        <h2>Resumo</h2>
        <div id="resumoFinal"></div>
        <div class="total-rodape"><span>TOTAL:</span><span id="finalTotal">R$ 0,00</span></div>
        <button class="btn-sucesso" style="margin-top: 10px;" onclick="reiniciarApp()">Nova Compra</button>
        <button class="btn-voltar" onclick="navegar('telaInicial')">Voltar</button>
    </div>
</div>

<script>
    let carrinho = JSON.parse(localStorage.getItem('carrinho')) || [];
    let dicionario = JSON.parse(localStorage.getItem('dicionario')) || {};
    let html5QrCode;

    function navegar(idTela) {
        document.querySelectorAll('.tela').forEach(t => t.classList.remove('ativa'));
        document.getElementById(idTela).classList.add('ativa');
        atualizarDashboards();
        if(idTela === 'telaCarrinho') renderizarLista('listaCarrinho', 'carrinhoSubtotal', true);
        if(idTela === 'telaFinalizar') renderizarLista('resumoFinal', 'finalTotal', true);
    }

    function alternarScanner() {
        const readerDiv = document.getElementById('reader');
        if (readerDiv.style.display === 'block') { pararScanner(); } 
        else {
            readerDiv.style.display = 'block';
            html5QrCode = new Html5Qrcode("reader");
            
            // Configuração simplificada para evitar chamar Realidade Aumentada
            const config = { 
                fps: 10, 
                qrbox: { width: 250, height: 150 },
                aspectRatio: 1.0 
            };

            html5QrCode.start(
                { facingMode: "environment" }, 
                config,
                (text) => {
                    document.getElementById('desc').value = dicionario[text] || text;
                    pararScanner();
                }
            ).catch(err => {
                console.error(err);
                alert("Dica: Se aparecer aviso de RA, clique em 'Sair' ou 'Voltar'. A câmera deve abrir em seguida.");
            });
        }
    }

    function pararScanner() { 
        if(html5QrCode && html5QrCode.isScanning) { 
            html5QrCode.stop().then(() => {
                document.getElementById('reader').style.display = 'none';
            });
        } else {
            document.getElementById('reader').style.display = 'none';
        }
    }

    function salvarProduto() {
        const index = parseInt(document.getElementById('editIndex').value);
        const desc = document.getElementById('desc').value;
        const qtd = parseInt(document.getElementById('qtd').value);
        const valor = parseFloat(document.getElementById('valor').value) || 0;
        
        if (desc && qtd > 0) {
            const produto = { desc, qtd, valor };
            if (index === -1) { carrinho.push(produto); } else { carrinho[index] = produto; }
            
            // Lógica simples de dicionário: se a descrição for apenas números, guarda como código
            if (/^\d+$/.test(desc)) { dicionario[desc] = desc; }

            localStorage.setItem('carrinho', JSON.stringify(carrinho));
            localStorage.setItem('dicionario', JSON.stringify(dicionario));
            navegar('telaInicial');
        }
    }

    function atualizarDashboards() {
        const total = carrinho.reduce((acc, item) => acc + (item.qtd * item.valor), 0);
        document.getElementById('homeTotal').innerText = total.toFixed(2);
        document.getElementById('homeQtd').innerText = carrinho.length.toString().padStart(2, '0');
    }

    function renderizarLista(containerId, totalId, edit) {
        const container = document.getElementById(containerId);
        container.innerHTML = '';
        let total = 0;
        carrinho.forEach((item, index) => {
            const sub = item.qtd * item.valor; total += sub;
            const div = document.createElement('div');
            div.className = 'item-carrinho';
            div.onclick = () => prepararEdicao(index);
            div.innerHTML = `<div><strong>${item.desc}</strong><br><small>${item.qtd}x R$ ${item.valor.toFixed(2)}</small></div><span>R$ ${sub.toFixed(2)}</span>`;
            container.appendChild(div);
        });
        document.getElementById(totalId).innerText = `R$ ${total.toFixed(2)}`;
    }

    function prepararAdd() {
        document.getElementById('tituloAcao').innerText = "Novo Produto";
        document.getElementById('editIndex').value = "-1";
        document.getElementById('btnExcluir').style.display = "none";
        document.getElementById('desc').value = ""; document.getElementById('qtd').value = "1"; document.getElementById('valor').value = "";
        navegar('telaAdd');
    }

    function prepararEdicao(index) {
        const item = carrinho[index];
        document.getElementById('tituloAcao').innerText = "Editar Produto";
        document.getElementById('editIndex').value = index;
        document.getElementById('btnExcluir').style.display = "block";
        document.getElementById('desc').value = item.desc;
        document.getElementById('qtd').value = item.qtd;
        document.getElementById('valor').value = item.valor;
        navegar('telaAdd');
    }

    function excluirProduto() {
        const index = document.getElementById('editIndex').value;
        if (index > -1 && confirm("Excluir este item?")) {
            carrinho.splice(index, 1);
            localStorage.setItem('carrinho', JSON.stringify(carrinho));
            navegar('telaInicial');
        }
    }

    function reiniciarApp() {
        if(confirm("Limpar lista atual?")) { 
            carrinho = []; 
            localStorage.setItem('carrinho', JSON.stringify(carrinho)); 
            navegar('telaInicial'); 
        }
    }

    atualizarDashboards();
</script>
</body>
</html>
